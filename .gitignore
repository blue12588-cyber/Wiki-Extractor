# --- Node / SvelteKit ---
node_modules/
.svelte-kit/
build/
.vite/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Rust / Cargo / Tauri ---
src-tauri/target/
target/
**/*.rs.bk

# --- OS / Editor ---
.DS_Store
Thumbs.db
Desktop.ini
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.swp
*.swo

# --- Build outputs ---
dist/
out/
bundle/

# --- Test outputs ---
playwright-report/
test-results/
coverage/

# --- Local env / secrets ---
.env
.env.local
.env.*.local
.envrc

# --- App-local data (must stay LOCAL, never committed) ---
# llmwiki app writes user data under data/ — never tracked
data/
data-*/

# --- Tauri runtime caches that occasionally leak ---
src-tauri/.cargo/
src-tauri/WixTools/

# --- Lockfile policy ---
# We DO commit package-lock.json and Cargo.lock per AC-LOCKFILE.
# We DO NOT commit yarn.lock or pnpm-lock.yaml in slice-1.
yarn.lock
pnpm-lock.yaml
