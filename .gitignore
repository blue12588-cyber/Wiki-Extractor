# Node / npm
node_modules/
npm-debug.log*
.npm/

# SvelteKit / Vite build outputs (regenerated from source)
.svelte-kit/
build/
.output/
.vercel/
.netlify/
.wrangler/
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Rust / Cargo
src-tauri/target/
sidecar/target/

# Tauri build artifacts (binaries, installers)
src-tauri/gen/
src-tauri/WixTools/

# Runtime data — install-folder-relative; never check in
data/

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Env files (keep examples committed)
.env
.env.*
!.env.example
!.env.test

# Editor / IDE
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo

# Logs
*.log
logs/
build-logs/

# MSVC resolver record (host-specific; regenerated on each build)
scripts/.last-msvc-resolution.txt
